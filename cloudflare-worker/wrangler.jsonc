{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "threshold-events",
  "main": "src/index.js",
  "compatibility_date": "2026-07-22",
  "workers_dev": true,

  "vars": {
    "ALLOWED_ORIGINS": "https://JRPrickett.github.io"
  },

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "threshold-analytics",
      "database_id": "6471b855-28ab-4453-8383-c3cbb190d528"
    }
  ]
}
